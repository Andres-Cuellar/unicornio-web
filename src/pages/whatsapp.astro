---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Whatsapp } from "simple-icons-astro";
import { number } from "../services.tsx";

const mensaje = encodeURIComponent("necesito una consulta con el brujo mayor");
const waUrl = `https://wa.me/${number}?text=${mensaje}`;
---

<Layout>
  <div class="relative flex min-h-screen w-full flex-col">
    <Header />
    <main
      class="flex flex-grow flex-col items-center justify-center px-4 py-24 text-center"
    >
      <div
        class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')] opacity-10 pointer-events-none"
      >
      </div>
      <div class="relative z-10 mx-auto max-w-2xl">
        <div class="mb-6 flex justify-center">
          <a
            class="flex h-24 w-24 items-center justify-center rounded-full bg-[#25D366] shadow-[0_0_40px_rgba(37,211,102,0.5)]"
            href={waUrl}
            target="_blank"
          >
            <Whatsapp size={52} color="#ffffff" />
          </a>
        </div>
        <h1
          class="mb-4 font-display text-4xl font-black text-white sm:text-5xl"
        >
          Habla con el Brujo Mayor
        </h1>
        <p class="mb-10 text-xl text-slate-300">
          Recibe una consulta personalizada. Resuelve tus dudas sobre amor,
          dinero, salud y más. El Brujo Mayor te está esperando.
        </p>
        <a
          href={waUrl}
          target="_blank"
          class="inline-flex animate-bounce items-center justify-center gap-3 rounded-full bg-[#25D366] px-10 py-8 text-xl font-bold text-white shadow-[0_0_40px_rgba(37,211,102,0.5)] transition-transform hover:scale-105 hover:shadow-[0_0_60px_rgba(37,211,102,0.7)]"
        >
          <Whatsapp size={20} color="#ffffff" />
          Necesito una consulta con el Brujo Mayor
        </a>
      </div>
    </main>
  </div>
</Layout>
