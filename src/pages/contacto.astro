---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Process from "../components/contacto/Process.astro";
import Services from "../components/Home/Services.astro";
import Testimonial from "../components/contacto/Testimonials.astro";
import Cta from "../components/contacto/Cta.astro";
import Hero from "../components/contacto/Hero.astro";

import "../styles/contacto.css";
import TestimonialVid from "../components/Home/TestimonialVid.astro";
---

<Layout>
    <Header />
    <!-- Hero Section -->
    <main class="flex-grow">
        <Hero />
        <Process />
        <Services />
        <Testimonial />
        <TestimonialVid />
        <Cta />
    </main>
    <footer class="bg-background-dark border-t border-white/10 py-12 px-4">
        <div
            class="mx-auto max-w-7xl flex flex-col md:flex-row justify-between items-center gap-6"
        >
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary"
                    >auto_awesome</span
                >
                <span class="text-lg font-bold text-white">Unicornio Negro</span
                >
            </div>
            <div class="text-slate-500 text-sm">
                © 2024 Unicornio Negro. Todos los derechos reservados.
            </div>
            <div class="flex gap-6">
                <a
                    class="text-slate-400 hover:text-primary transition-colors"
                    href="#">Privacidad</a
                >
                <a
                    class="text-slate-400 hover:text-primary transition-colors"
                    href="#">Términos</a
                >
            </div>
        </div>
    </footer>
</Layout>
