---
import { Facebook, Instagram } from "simple-icons-astro";
import { number, facebook, instagram } from "../services.tsx";
---

<footer class="relative overflow-hidden bg-background-dark py-20">
    <!-- Gold particle dust effect (simulated with bg image) -->
    <div
        class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')] opacity-20"
    >
    </div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center">
        <h2
            class="mb-6 font-display text-4xl font-black text-white sm:text-5xl"
        >
            Tu Destino te Espera
        </h2>
        <p class="mb-10 text-xl text-slate-300">
            No dejes pasar más tiempo sufriendo por amor o falta de dinero. El
            Brujo Mayor tiene la solución.
        </p>
        <a
            class="inline-flex h-16 animate-bounce items-center justify-center gap-3 rounded-full bg-primary px-10 text-lg font-bold text-black shadow-[0_0_40px_rgba(212,175,55,0.5)] transition-transform hover:scale-105"
            href={`https://wa.me/${number}`}
            target="_blank"
        >
            <span class="material-symbols-outlined text-3xl">chat</span>
            HABLA CON EL BRUJO MAYOR
        </a>
        <div class="mt-10 flex justify-center gap-6">
            <a
                class="flex h-10 w-10 items-center justify-center rounded-full border border-[#302839] text-slate-400 transition-all hover:border-[#1877F2] hover:text-[#1877F2]"
                href={facebook}
                target="_blank"
                aria-label="Facebook"
            >
                <Facebook size={18} />
            </a>
            <a
                class="flex h-10 w-10 items-center justify-center rounded-full border border-[#302839] text-slate-400 transition-all hover:border-[#E1306C] hover:text-[#E1306C]"
                href={instagram}
                target="_blank"
                aria-label="Instagram"
            >
                <Instagram size={18} />
            </a>
        </div>
        <div
            class="mt-8 flex justify-center gap-8 border-t border-[#302839] pt-8 text-sm text-slate-500"
        >
            <a class="hover:text-primary" href="#">Términos y Condiciones</a>
            <a class="hover:text-primary" href="#">Política de Privacidad</a>
        </div>
        <p class="mt-4 text-xs text-slate-600">
            © 2026 Unicornio Negro. Servicios exclusivos para mayores de 18
            años.
        </p>
    </div>
</footer>
