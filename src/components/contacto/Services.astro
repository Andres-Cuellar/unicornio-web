---
import { number } from "../../services";

const waUrl = (msg: string) =>
  `https://wa.me/${number}?text=${encodeURIComponent(msg)}`;

const links = {
  amarres: waUrl("Hola, quiero saber sobre los Amarres de Amor."),
  abreCaminos: waUrl("Hola, quiero saber sobre el servicio Abre Caminos."),
  limpias: waUrl("Hola, quiero saber sobre las Limpias Energéticas."),
};
---

<section class="py-24 px-4 bg-background-dark">
  <div class="mx-auto max-w-7xl">
    <div
      class="mb-16 flex flex-col items-start justify-between gap-4 md:flex-row md:items-end"
    >
      <div>
        <h2 class="text-3xl font-bold text-white md:text-5xl">
          Nuestros Servicios
        </h2>
        <p class="mt-2 text-slate-400">
          Rituales de alta potencia para cada necesidad
        </p>
      </div>
      <a
        class="flex items-center text-secondary hover:text-white transition-colors"
        href="#"
      >
        Ver todo el catálogo <span
          class="material-symbols-outlined ml-1 text-sm">arrow_forward</span
        >
      </a>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <!-- Service Card 1 -->
      <div
        class="group relative overflow-hidden rounded-xl bg-surface-dark p-1 transition-all hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.4)]"
      >
        <div
          class="absolute inset-0 bg-gradient-to-b from-primary/20 via-transparent to-transparent opacity-0 transition-opacity group-hover:opacity-100"
        >
        </div>
        <div
          class="relative h-full overflow-hidden rounded-lg bg-background-dark p-8 border border-white/5 group-hover:border-primary/50"
        >
          <div
            class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary/20 text-primary"
          >
            <span class="material-symbols-outlined text-2xl">favorite</span>
          </div>
          <h3 class="mb-3 text-2xl font-bold text-white font-display">
            Amarres de Amor
          </h3>
          <p class="mb-6 text-sm leading-relaxed text-slate-400">
            Recupera a tu pareja o atrae el amor verdadero con rituales de unión
            eterna y endulzamientos.
          </p>
          <a
            class="inline-flex items-center text-sm font-bold text-secondary group-hover:text-white transition-colors"
            href={links.amarres}
            target="_blank"
            rel="noopener noreferrer"
          >
            Detalles del ritual <span
              class="material-symbols-outlined ml-1 text-base"
              >arrow_forward</span
            >
          </a>
        </div>
      </div>
      <!-- Service Card 2 -->
      <div
        class="group relative overflow-hidden rounded-xl bg-surface-dark p-1 transition-all hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.4)]"
      >
        <div
          class="absolute inset-0 bg-gradient-to-b from-primary/20 via-transparent to-transparent opacity-0 transition-opacity group-hover:opacity-100"
        >
        </div>
        <div
          class="relative h-full overflow-hidden rounded-lg bg-background-dark p-8 border border-white/5 group-hover:border-primary/50"
        >
          <div
            class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary/20 text-primary"
          >
            <span class="material-symbols-outlined text-2xl">key</span>
          </div>
          <h3 class="mb-3 text-2xl font-bold text-white font-display">
            Abre Caminos
          </h3>
          <p class="mb-6 text-sm leading-relaxed text-slate-400">
            Elimina obstáculos en tu vida financiera y profesional. Atrae
            abundancia y prosperidad inmediata.
          </p>
          <a
            class="inline-flex items-center text-sm font-bold text-secondary group-hover:text-white transition-colors"
            href={links.abreCaminos}
            target="_blank"
            rel="noopener noreferrer"
          >
            Detalles del ritual <span
              class="material-symbols-outlined ml-1 text-base"
              >arrow_forward</span
            >
          </a>
        </div>
      </div>
      <!-- Service Card 3 -->
      <div
        class="group relative overflow-hidden rounded-xl bg-surface-dark p-1 transition-all hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.4)]"
      >
        <div
          class="absolute inset-0 bg-gradient-to-b from-primary/20 via-transparent to-transparent opacity-0 transition-opacity group-hover:opacity-100"
        >
        </div>
        <div
          class="relative h-full overflow-hidden rounded-lg bg-background-dark p-8 border border-white/5 group-hover:border-primary/50"
        >
          <div
            class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary/20 text-primary"
          >
            <span class="material-symbols-outlined text-2xl">shield</span>
          </div>
          <h3 class="mb-3 text-2xl font-bold text-white font-display">
            Limpias Energéticas
          </h3>
          <p class="mb-6 text-sm leading-relaxed text-slate-400">
            Protégete de envidias, mal de ojo y brujería oscura. Restaura tu
            equilibrio espiritual.
          </p>
          <a
            class="inline-flex items-center text-sm font-bold text-secondary group-hover:text-white transition-colors"
            href={links.limpias}
            target="_blank"
            rel="noopener noreferrer"
          >
            Detalles del ritual <span
              class="material-symbols-outlined ml-1 text-base"
              >arrow_forward</span
            >
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
